# Gateway Server Config
PORT=8000
HOST=0.0.0.0

# OpenRouter API Config
# Obtain key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model & inference
MODEL=google/gemini-2.0-flash-exp:free
TEMPERATURE=0.7
MAX_TOOL_CALLS=5

# AI Mode: "isolated" (portfolio-only assistant) or "open" (general-purpose assistant)
AI_MODE=isolated

# Comma-separated list of regex patterns to detect model errors
ERROR_PATTERNS=does not support image,cannot read,image input,does not support

# Redis Session Store Config (optional — leave blank to use in-memory)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
